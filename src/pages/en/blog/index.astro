---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { useTranslations } from "../../../i18n/utils";

import { site } from "../../../data/site";

const t = useTranslations("en");

const posts = (await getCollection("blog", ({ data }) =>
  !data.draft && data.lang === "en"
)).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title={`Blog — ${site.name}`} description="Articles about software development, technology and learnings.">
  <div class="mx-auto max-w-[var(--container-content)] px-6 py-16">

    <h1 class="text-3xl font-bold text-[var(--color-text)] mb-2">{t.blog.title}</h1>
    <p class="text-[var(--color-text-muted)] mb-12">{t.blog.all_posts}</p>

    {posts.length === 0 ? (
      <p class="text-[var(--color-text-muted)]">{t.blog.empty}</p>
    ) : (
      <ul class="space-y-8">
        {posts.map((post) => {
          const date = post.data.pubDate.toLocaleDateString("en-US", {
            year: "numeric",
            month: "long",
            day: "numeric",
          });
          return (
            <li>
              <article class="group">
                <time
                  datetime={post.data.pubDate.toISOString()}
                  class="text-xs text-[var(--color-text-muted)] mb-1 block"
                >
                  {date}
                </time>
                <a href={`/en/blog/${post.id}`}>
                  <h2 class="text-xl font-semibold text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors mb-1">
                    {post.data.title}
                  </h2>
                </a>
                <p class="text-[var(--color-text-muted)] text-sm leading-relaxed mb-3">
                  {post.data.description}
                </p>
                {post.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-1.5">
                    {post.data.tags.map((tag: string) => (
                      <span class="text-xs px-2 py-0.5 rounded-full bg-[var(--color-surface)] border border-[var(--color-border)] text-[var(--color-text-muted)]">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
              </article>
              <hr class="border-[var(--color-border)] mt-8" />
            </li>
          );
        })}
      </ul>
    )}

  </div>
</BaseLayout>
