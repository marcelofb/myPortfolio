---
/*
  Props son los parámetros que recibe el layout.
  interface define la forma del objeto — TypeScript verifica
  que quien use este layout pase los datos correctos.
*/
import { ClientRouter } from "astro:transitions";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import UnderConstruction from "../components/UnderConstruction.astro";
import { getLangFromUrl, getAlternateUrl } from "../i18n/utils";
import { site } from "../data/site";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  ogImage?: string; // opcional — imagen para compartir en redes
}

const {
  title,
  description,
  ogImage = "/og-image.png",
} = Astro.props;

const lang = getLangFromUrl(Astro.url);
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
/*
  hreflang: le dice a Google que existe una versión alternativa en otro idioma.
  - hreflang="es" → esta URL es la versión en español
  - hreflang="en" → esta URL es la versión en inglés
  - hreflang="x-default" → versión por defecto si ningún idioma hace match
  getAlternateUrl() calcula la URL del otro idioma a partir de la URL actual.
*/
const alternateUrl = new URL(getAlternateUrl(Astro.url), Astro.site);
const hreflangSelf = lang === "es" ? "es" : "en";
const hreflangOther = lang === "es" ? "en" : "es";
---

<!doctype html>
<html lang={lang} class="">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO básico -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!--
      hreflang: informa a Google sobre las versiones en otros idiomas.
      x-default = la URL que Google muestra a usuarios sin preferencia de idioma.
    -->
    <link rel="alternate" hreflang={hreflangSelf} href={canonicalURL} />
    <link rel="alternate" hreflang={hreflangOther} href={alternateUrl} />
    <link rel="alternate" hreflang="x-default" href={new URL("/", Astro.site)} />

    <!-- Open Graph — controla cómo se ve el link al compartir en LinkedIn, Twitter, etc. -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />

    <!-- Twitter/X card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!--
      ViewTransitions activa la View Transitions API del browser.
      Convierte cada navegación entre páginas en una transición animada
      (fade por defecto) sin recargar el DOM completo.
      En browsers que no lo soportan, cae silenciosamente a navegación normal.
    -->
    <ClientRouter />

    <!-- Fuente Inter desde Google Fonts — display=swap evita que el texto sea invisible mientras carga -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!--
      Script anti-flash de dark mode.
      Va en el <head> para ejecutarse ANTES de que el browser pinte
      cualquier cosa. Sin esto, la página parpadea de claro a oscuro
      cuando el usuario tiene dark mode activado.
    -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem("theme");
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        if (stored === "dark" || (!stored && prefersDark)) {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>
  </head>
  <body class="bg-[var(--color-bg)] text-[var(--color-text)]">
    <UnderConstruction />
    <Nav />
    <!--
      <slot /> es donde Astro inyecta el contenido de la página hija.
      Es el equivalente a {children} en React.
    -->
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
