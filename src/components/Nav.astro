---
/*
  Frontmatter: el bloque entre --- es TypeScript que corre en el SERVER
  (en build time). Acá importamos utilidades, definimos props, etc.
  El resultado es HTML estático — no llega al browser como JS.
*/
import { getLangFromUrl, useTranslations, getAlternateUrl } from "../i18n/utils";
import { site } from "../data/site";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const alternateUrl = getAlternateUrl(Astro.url);
const showBlogLink = false;
---

<header class="sticky top-0 z-50 w-full border-b border-[var(--color-border)] bg-[var(--color-bg)]/90 backdrop-blur-sm">
  <nav class="mx-auto flex max-w-[var(--container-wide)] items-center justify-between px-6 py-4">
    
    <!-- Izquierda: hamburguesa (mobile) + logo -->
    <div class="flex items-center gap-3">
      <!-- Hamburguesa — solo en mobile -->
      <button
        id="menu-toggle"
        aria-label="Abrir menú"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="md:hidden w-8 h-8 flex items-center justify-center rounded text-[var(--color-text-muted)] hover:text-[var(--color-text)] hover:bg-[var(--color-surface)] transition-colors"
      >
        <!-- Ícono hamburguesa -->
        <svg id="icon-menu" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
        <!-- Ícono X (cerrar) -->
        <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>

      <!-- Logo / nombre -->
      <a href={lang === "en" ? "/en/" : "/"} class="text-sm font-semibold tracking-tight text-[var(--color-text)] hover:text-[var(--color-accent)] transition-colors">
        {site.initials}
      </a>
    </div>

    <!-- Links de sección — solo visibles en desktop -->
    <ul class="hidden md:flex items-center gap-6 text-sm text-[var(--color-text-muted)]">
      <li><a href={lang === "en" ? "/en/#about" : "/#about"} class="hover:text-[var(--color-text)] transition-colors">{t.nav.about}</a></li>
      <li><a href={lang === "en" ? "/en/#experience" : "/#experience"} class="hover:text-[var(--color-text)] transition-colors">{t.nav.experience}</a></li>
      <li><a href={lang === "en" ? "/en/#projects" : "/#projects"} class="hover:text-[var(--color-text)] transition-colors">{t.nav.projects}</a></li>
      <li><a href={lang === "en" ? "/en/#skills" : "/#skills"} class="hover:text-[var(--color-text)] transition-colors">{t.nav.skills}</a></li>
      <li><a href={lang === "en" ? "/en/#contact" : "/#contact"} class="hover:text-[var(--color-text)] transition-colors">{t.nav.contact}</a></li>
      {showBlogLink && <li><a href={lang === "en" ? "/en/blog" : "/blog"} class="hover:text-[var(--color-text)] transition-colors">{t.nav.blog}</a></li>}
    </ul>

    <!-- Acciones: idioma + dark mode -->
    <div class="flex items-center gap-3">
      
      <!-- Toggle de idioma -->
      <a
        href={alternateUrl}
        class="text-xs font-medium px-2 py-1 rounded border border-[var(--color-border)] text-[var(--color-text-muted)] hover:text-[var(--color-text)] hover:border-[var(--color-text)] transition-colors"
        aria-label="Switch language"
      >
        {lang === "es" ? "EN" : "ES"}
      </a>

      <!-- Toggle dark/light mode -->
      <button
        id="theme-toggle"
        aria-label="Toggle dark mode"
        class="w-8 h-8 flex items-center justify-center rounded text-[var(--color-text-muted)] hover:text-[var(--color-text)] hover:bg-[var(--color-surface)] transition-colors"
      >
        <!-- Ícono sol (visible en dark mode) -->
        <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="hidden">
          <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <!-- Ícono luna (visible en light mode) -->
        <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Menú mobile -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-[var(--color-border)] bg-[var(--color-bg)]"
  >
    <ul class="flex flex-col px-6 py-4 gap-4 text-sm text-[var(--color-text-muted)]">
      <li><a href={lang === "en" ? "/en/#about" : "/#about"} class="block hover:text-[var(--color-text)] transition-colors">{t.nav.about}</a></li>
      <li><a href={lang === "en" ? "/en/#experience" : "/#experience"} class="block hover:text-[var(--color-text)] transition-colors">{t.nav.experience}</a></li>
      <li><a href={lang === "en" ? "/en/#projects" : "/#projects"} class="block hover:text-[var(--color-text)] transition-colors">{t.nav.projects}</a></li>
      <li><a href={lang === "en" ? "/en/#skills" : "/#skills"} class="block hover:text-[var(--color-text)] transition-colors">{t.nav.skills}</a></li>
      <li><a href={lang === "en" ? "/en/#contact" : "/#contact"} class="block hover:text-[var(--color-text)] transition-colors">{t.nav.contact}</a></li>
      {showBlogLink && <li><a href={lang === "en" ? "/en/blog" : "/blog"} class="block hover:text-[var(--color-text)] transition-colors">{t.nav.blog}</a></li>}
    </ul>
  </div>
</header>

<!--
  Script del dark mode.
  is:inline hace que Astro NO procese ni agrupe este script —
  se inyecta tal cual en el HTML. Lo necesitamos así porque debe
  ejecutarse ANTES que el CSS cargue, para evitar el "flash" de
  tema incorrecto al recargar la página.
-->
<script is:inline>
  function applyTheme() {
    const stored = localStorage.getItem("theme");
    const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
    const isDark = stored === "dark" || (!stored && prefersDark);
    document.documentElement.classList.toggle("dark", isDark);
    updateIcons(isDark);
  }

  function updateIcons(isDark) {
    const sun = document.getElementById("icon-sun");
    const moon = document.getElementById("icon-moon");
    if (sun) sun.classList.toggle("hidden", !isDark);
    if (moon) moon.classList.toggle("hidden", isDark);
  }

  function setupToggle() {
    document.getElementById("theme-toggle")?.addEventListener("click", () => {
      const isDark = document.documentElement.classList.toggle("dark");
      localStorage.setItem("theme", isDark ? "dark" : "light");
      updateIcons(isDark);
    });
  }

  function setupMenu() {
    const toggle = document.getElementById("menu-toggle");
    const menu = document.getElementById("mobile-menu");
    const iconMenu = document.getElementById("icon-menu");
    const iconClose = document.getElementById("icon-close");
    if (!toggle || !menu) return;

    function closeMenu() {
      menu.classList.add("hidden");
      iconMenu.classList.remove("hidden");
      iconClose.classList.add("hidden");
      toggle.setAttribute("aria-expanded", "false");
    }

    toggle.addEventListener("click", () => {
      const isOpen = !menu.classList.contains("hidden");
      if (isOpen) {
        closeMenu();
      } else {
        menu.classList.remove("hidden");
        iconMenu.classList.add("hidden");
        iconClose.classList.remove("hidden");
        toggle.setAttribute("aria-expanded", "true");
      }
    });

    // Cerrar el menú al hacer click en cualquier link
    menu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", closeMenu);
    });
  }

  // Aplica el tema al cargar y re-engancha el listener después de cada
  // View Transition (astro:after-swap se dispara cuando Astro swapea el DOM).
  applyTheme();
  setupToggle();
  setupMenu();
  document.addEventListener("astro:after-swap", () => {
    applyTheme();
    setupToggle();
    setupMenu();
  });
</script>
