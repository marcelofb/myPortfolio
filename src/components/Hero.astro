---
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import { site } from "../data/site";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<!--
  id="about" → el Nav tiene <a href="#about"> que hace scroll hasta acá.
  min-h-screen → la sección ocupa al menos toda la pantalla.
-->
<section id="about" class="min-h-screen flex items-center py-24">
  <div class="mx-auto max-w-[var(--container-wide)] px-6 w-full">
    <div class="grid grid-cols-1 md:grid-cols-[1fr_auto] gap-12 items-center">

      <!-- Columna de texto -->
      <div class="space-y-6 max-w-lg">

        <!-- Badge de disponibilidad -->
        <div class="inline-flex items-center gap-2 text-sm text-[var(--color-text-muted)]">
          <!--
            animate-pulse es una clase de Tailwind que genera
            una animación CSS de opacidad (fade in/out).
            bg-green-500 usa la paleta de verdes de Tailwind.
          -->
          <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
          {t.hero.available}
        </div>

        <!-- Saludo + nombre + rol -->
        <div>
          <p class="text-[var(--color-text-muted)] text-lg mb-1">{t.hero.greeting}</p>
          <h1 class="text-5xl font-bold tracking-tight text-[var(--color-text)] mb-3 leading-tight">
            {site.name}
          </h1>
          <p class="text-xl text-[var(--color-accent)] font-medium">{site.role[lang]}</p>
        </div>

        <!-- Bio -->
        <p class="text-[var(--color-text-muted)] leading-relaxed">
          {t.hero.bio}
        </p>

        <!-- Botones de acción -->
        <div class="flex flex-wrap gap-3">
          <!--
            download es un atributo HTML nativo: hace que el link
            descargue el archivo en lugar de navegar a él.
          -->
          <a
            href={site.cv}
            download
            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-[var(--color-accent)] text-white font-medium text-sm hover:bg-[var(--color-accent-hover)] transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
              <polyline points="7 10 12 15 17 10"/>
              <line x1="12" y1="15" x2="12" y2="3"/>
            </svg>
            {t.hero.cta_cv}
          </a>
          <a
            href="#contact"
            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg border border-[var(--color-border)] text-[var(--color-text)] font-medium text-sm hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-colors"
          >
            {t.hero.cta_contact}
          </a>
        </div>

        <!-- Links sociales -->
        <div class="flex items-center gap-5 pt-2">
          <a
            href={site.github}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub"
            class="text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.385-1.335-1.755-1.335-1.755-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.295 24 12c0-6.63-5.37-12-12-12"/>
            </svg>
          </a>
          <a
            href={site.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
            class="text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <a
            href={`mailto:${site.email}`}
            class="text-sm text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors font-medium"
          >
            {site.email}
          </a>
        </div>
      </div>

      <!-- Avatar placeholder (solo visible en desktop) -->
      <div class="hidden md:flex justify-center items-center">
        <!--
          Este bloque es el placeholder del avatar.
          Reemplazalo con:
          <img src="/foto.jpg" alt="Tu Nombre" class="w-48 h-48 rounded-2xl object-cover" />
          cuando tengas tu foto lista.
        -->
        <div class="w-52 h-52 rounded-2xl bg-[var(--color-surface)] border border-[var(--color-border)] flex items-center justify-center select-none">
          <span class="text-5xl font-bold text-[var(--color-border)]">{site.initials}</span>
        </div>
      </div>

    </div>
  </div>
</section>
