---
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import { site } from "../data/site";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--color-border)] py-8 mt-24">
  <div class="mx-auto max-w-[var(--container-wide)] px-6 flex flex-col items-center justify-center gap-4 text-sm text-[var(--color-text-muted)] text-center">

    <p>
      © {year} {site.name} — {t.footer.built_with}
      <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-accent)] transition-colors">Astro</a>
      {t.footer.and}
      <a href="https://tailwindcss.com" target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-accent)] transition-colors">Tailwind</a>
    </p>

  </div>
</footer>
