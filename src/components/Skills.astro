---
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import { skills } from "../data/skills";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="skills" class="py-20 bg-[var(--color-bg-subtle)]">
  <div class="mx-auto max-w-[var(--container-wide)] px-6">
    <h2 class="text-2xl font-bold text-[var(--color-text)] mb-12">{t.skills.title}</h2>

    <!--
      grid adaptativo: 1 col mobile → 2 cols tablet → 3 cols desktop
    -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {skills.map((group) => (
        <div>
          <!--
            uppercase tracking-wider → texto en mayúsculas con más espacio entre letras.
            Es un patrón visual común para labels de categoría.
          -->
          <h3 class="text-xs font-semibold text-[var(--color-text)] uppercase tracking-wider mb-3">
            {group.category[lang]}
          </h3>
          <div class="flex flex-wrap gap-2">
            {group.items.map((item) => (
              <span class="text-sm px-3 py-1 rounded-lg bg-[var(--color-surface)] border border-[var(--color-border)] text-[var(--color-text-muted)]">
                {item}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
